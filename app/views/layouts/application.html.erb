<!DOCTYPE html>
<html>
  <head>
    <title>Timbox</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <% if user_signed_in? %>
      <div data-controller="sidebar" class="d-flex flex-column vh-100">
        
        <nav class="navbar navbar-dark bg-dark px-3 flex-shrink-0">
          <div class="d-flex align-items-center">
            <button class="btn btn-outline-light me-3" data-action="click->sidebar#toggle">
              ☰
            </button>
            <a class="navbar-brand" href="#">YourApp</a>
          </div>
          
          <div class="d-flex align-items-center text-white">
            <span class="me-3">Hola, <%= current_user.email %></span>
            <%= button_to "Cerrar Sesión", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-danger" %>
          </div>
        </nav>

        <div class="d-flex flex-grow-1 overflow-hidden">
          
          <aside data-sidebar-target="menu" class="bg-light border-end w-25 p-3 overflow-auto" style="min-width: 250px; max-width: 300px;">
            <ul class="nav nav-pills flex-column mb-auto">
              <li class="nav-item">
                <%= link_to "Colaboradores", employees_path, class: "nav-link link-dark" %>
              </li>
              <li>
                <%= link_to "Configuración de Cuenta", "#", class: "nav-link link-dark" %>
              </li>
              <li>
                <%= link_to "Algoritmos", "#", class: "nav-link link-dark" %>
              </li>

              <li>
                <%= link_to "Usuarios", client_users_path, class: "nav-link text-primary fw-bold" %>
              </li>
    
              <li>
                <%= link_to "Servicios", posts_path, class: "nav-link link-dark" %>
              </li>
            </ul>
          </aside>

          <main class="flex-grow-1 p-4 overflow-auto bg-white">
            <%= render "layouts/alerts" %> <%= turbo_frame_tag "main-content", data: { turbo_action: "advance" } do %>
              <%= yield %>
            <% end %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="container mt-5">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
