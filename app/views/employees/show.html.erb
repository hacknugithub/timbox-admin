<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="card-title mb-4"><%= @employee.name %></h2>

          <dl class="row">
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8"><%= @employee.email %></dd>

            <dt class="col-sm-4">RFC</dt>
            <dd class="col-sm-8"><%= @employee.rfc %></dd>

            <dt class="col-sm-4">Departamento</dt>
            <dd class="col-sm-8"><%= @employee.department %></dd>

            <dt class="col-sm-4">Tipo de Contrato</dt>
            <dd class="col-sm-8"><%= @employee.contract_type %></dd>

            <dt class="col-sm-4">Fecha de Ingreso</dt>
            <dd class="col-sm-8"><%= @employee.started_working_at&.strftime("%d/%m/%Y") %></dd>
          </dl>

          <div class="d-flex justify-content-end gap-2 mt-4">
            <%= link_to "Editar", edit_employee_path(@employee), class: "btn btn-primary btn-sm" %>
            <%= button_to "Eliminar", employee_path(@employee),
                  method: :delete,
                  form: { data: { turbo_confirm: "¿Estás seguro de que deseas eliminar este colaborador?", turbo_frame: "_top" } },
                  class: "btn btn-danger btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
