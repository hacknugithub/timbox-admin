<%= form_with(model: post, id: dom_id(post, "form"), html: { novalidate: true }) do |form| %>
  <div class="mb-3">
    <%= form.label :title, "Título", class: "form-label" %>
    <%= form.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= form.label :body, "Contenido", class: "form-label" %>
    <%= form.text_area :body, class: "form-control", rows: 3, required: true %>
  </div>

  <div class="d-flex justify-content-end gap-2">
    <% if post.persisted? %>
      <%= link_to "Cancelar", posts_path, class: "btn btn-outline-secondary", data: { turbo_frame: "_top" } %>
    <% end %>
    <%= form.submit "Guardar Publicación", class: "btn btn-primary" %>
  </div>
<% end %>