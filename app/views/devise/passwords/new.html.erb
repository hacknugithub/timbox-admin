<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="card-title mb-4">Recuperar contraseña</h2>

          <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "needs-validation", novalidate: true }) do |f| %>
            <%= f.error_notification class: "alert alert-danger" %>

            <div class="form-inputs">
              <%= f.input :email,
                          required: true,
                          autofocus: true,
                          input_html: { autocomplete: "email", class: "form-control" },
                          wrapper_html: { class: "mb-3" } %>
              <%= f.input :rfc,
                          required: true,
                          input_html: { autocomplete: "off", class: "form-control text-uppercase" },
                          wrapper_html: { class: "mb-3" } %>
            </div>

            <div class="d-grid">
              <%= f.button :submit, "Enviar instrucciones", class: "btn btn-primary" %>
            </div>
          <% end %>

          <div class="mt-3">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
