<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="card-title mb-4">Iniciar sesión</h2>

          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "needs-validation", novalidate: true }) do |f| %>
            <div class="form-inputs">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          input_html: { autocomplete: "email", class: "form-control" },
                          wrapper_html: { class: "mb-3" } %>
              <%= f.input :password,
                          required: false,
                          input_html: { autocomplete: "current-password", class: "form-control" },
                          wrapper_html: { class: "mb-3" } %>
              <%= f.input :remember_me, as: :boolean, wrapper_html: { class: "form-check mb-3" }, input_html: { class: "form-check-input" } if devise_mapping.rememberable? %>
            </div>

            <div class="d-grid">
              <%= f.button :submit, "Ingresar", class: "btn btn-primary" %>
            </div>
          <% end %>

          <div class="mt-3">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
