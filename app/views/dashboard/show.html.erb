<div class="d-flex flex-column justify-content-between align-items-center mb-4">
  <div class="d-flex justify-content-between w-100">
    <h2>Últimos Clientes</h2>
  </div>
<div class="table-responsive w-100">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Nombre</th>
        <th>RFC</th>
        <th>Dirección</th>
        <th>Telefono</th>
        <th>Sitio Web</th>
        <th>Creado por</th> 
      </tr>
    </thead>
    <tbody>
      <% if @client_users.any? %>
        <% @client_users.each do |client_user| %>
          <tr>
            <td><%= client_user.name %></td>
            <td><%= client_user.rfc %></td>
            <td><%= client_user.address %></td>
            <td><%= client_user.phone %></td>
            <td><%= client_user.website %></td>
            <td><%= client_user.user.email %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="6" class="text-center text-muted py-4">No hay clientes registrados todavía.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>