<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Últimos Colaboradores</h2>
  <%= link_to "Ver todos", "#", class: "btn btn-primary btn-sm" %>
</div>

<div class="table-responsive">
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>RFC</th>
        <th>Department</th>
        <th>Contract Type</th>
        <th>Started At</th>
      </tr>
    </thead>
    <tbody>
      <% if @employees.any? %>
        <% @employees.each do |employee| %>
          <tr>
            <td><%= employee.name %></td>
            <td><%= employee.email %></td>
            <td><%= employee.rfc %></td>
            <td><%= employee.department %></td>
            <td><%= employee.contract_type %></td>
            <td><%= employee.started_at&.strftime("%d/%m/%Y") %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="6" class="text-center text-muted py-4">No hay colaboradores registrados todavía.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>